{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "pulse",
  "title": "Pulse CLI",
  "description": "System health monitoring and cache cleanup for macOS developers",
  "version": "0.1.0",
  "categories": [
    "Developer Tools",
    "System"
  ],
  "license": "MIT",
  "private": true,
  "commands": [
    {
      "name": "analyze",
      "title": "Analyze System",
      "description": "Scan for cleanup candidates and reclaimable space",
      "mode": "view"
    },
    {
      "name": "clean",
      "title": "Preview Cleanup",
      "description": "Preview what Pulse CLI would clean (dry run)",
      "mode": "view"
    },
    {
      "name": "doctor",
      "title": "Run Doctor",
      "description": "Verify Pulse installation and environment",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "pulsePath",
      "title": "Pulse CLI Path",
      "description": "Path to the pulse binary",
      "type": "textfield",
      "default": "/usr/local/bin/pulse",
      "required": false
    }
  ],
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint"
  },
  "dependencies": {
    "@raycast/api": "^1.0.0",
    "@raycast/utils": "^2.2.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
